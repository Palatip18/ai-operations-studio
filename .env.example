# The MVP runs in deterministic mock mode without any credentials.
AI_PROVIDER=mock

# Password-gated portfolio demo access (required to open the demo).
# Set a non-secret sample value locally. This gates demo access only and is
# NOT production authentication. Never commit a real value; .env.local is ignored.
DEMO_PASSWORD=change-me-demo-password

# Optional future provider integration. Never commit real values.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
AI_BASE_URL=https://api.openai.com/v1
